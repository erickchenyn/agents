#!/bin/bash

# wc - Unified Workspace Management Tool
# Supports both workspace creation and checkout operations

set -e

# 获取脚本目录
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# 颜色输出
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

print_info() {
    echo -e "${BLUE}[INFO]${NC} $1"
}

print_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

# 显示帮助信息
show_help() {
    cat << EOF
wc - Workspace Management Tool

Usage:
    wc create [OPTIONS]                 Create new workspace
    wc checkout [OPTIONS] <branch|pr>   Checkout/create workspace for branch or PR
    wc remove [OPTIONS]                 Remove worktrees and merge Claude settings
    wc -h, --help                       Show this help

Subcommands:
    create      Create a new git worktree and branch for parallel development
    checkout    Switch to existing worktree or create new one for given branch/PR
    remove      Remove all safe worktrees with settings backup (unsafe ones skipped)

Create Options:
    -h, --help              Show help message
    -d, --dry-run           Preview mode, don't actually execute operations
    -b, --branch <name>     Custom branch name (default: timestamp-based)
    -u, --user <name>       Set git user name (default: erick.chen)
    -e, --email <email>     Set git user email (default: erick.chen@paraflow.com)

Checkout Options:
    -h, --help              Show help message
    -d, --dry-run           Preview mode, don't actually execute operations
    -u, --user <name>       Set git user name (default: erick.chen)
    -e, --email <email>     Set git user email (default: erick.chen@paraflow.com)

Remove Options:
    -h, --help              Show help message
    -d, --dry-run           Preview mode, don't actually execute operations

Examples:
    # Create operations
    wc create                           # Create new workspace with timestamp branch
    wc create -d                        # Preview create operation
    wc create -b feature-auth           # Create workspace with specific branch name
    wc create -d -b hotfix -u jane      # Preview create with custom branch and user

    # Checkout operations
    wc checkout feature-login           # Checkout branch feature-login
    wc checkout 123                     # Checkout PR #123
    wc checkout -d fix-bug-issue        # Preview checkout operation
    wc checkout -u john 456             # Checkout PR #456 with custom user

    # Remove operations
    wc remove                           # Remove all safe worktrees, skip unsafe ones
    wc remove -d                        # Preview removal of all worktrees

Environment Variables:
    GIT_USER_NAME           Default git user name
    GIT_USER_EMAIL          Default git user email
    BRANCH_PREFIX           Default branch prefix for create

EOF
}

# 主函数
main() {
    if [[ $# -eq 0 ]]; then
        show_help
        exit 1
    fi

    local subcommand="$1"
    shift

    case "$subcommand" in
        create)
            # 调用 workspace-create.sh
            exec "$SCRIPT_DIR/workspace-create.sh" "$@"
            ;;
        checkout)
            # 调用 workspace-checkout.sh
            exec "$SCRIPT_DIR/workspace-checkout.sh" "$@"
            ;;
        remove)
            # 调用 workspace-remove.sh
            exec "$SCRIPT_DIR/workspace-remove.sh" "$@"
            ;;
        -h|--help)
            show_help
            exit 0
            ;;
        *)
            print_error "Unknown subcommand: $subcommand"
            print_info "Available subcommands: create, checkout, remove"
            show_help
            exit 1
            ;;
    esac
}

main "$@"